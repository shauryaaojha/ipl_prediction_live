# ============================================
# IPL 2026 Data Scraper — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control!

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ipl2026
DB_USER=ipl_user
DB_PASSWORD=shaurya2006

# --- API Keys (Optional — for weather data) ---
OPENWEATHER_API_KEY=your_openweathermap_key_here
VISUALCROSSING_API_KEY=your_visualcrossing_key_here

# --- Scraping ---
PROXY_LIST=                        # Comma-separated: http://proxy1:8080,http://proxy2:8080
ENABLE_BROWSER=false               # Set to true to enable Playwright browser automation
HEADLESS=true                      # Set to false to see browser window (debugging)

# --- Application ---
LOG_LEVEL=INFO
DATA_PATH=./data                   # Base path for data storage
ENVIRONMENT=production             # development / production
